# Copy this file to .env and fill in real values. DO NOT COMMIT .env.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Supabase project the app reads/writes (REST + Auth).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Gemini API key for the AI assistant. SERVER-SIDE ONLY — set this in the
# hosting environment (e.g. Vercel project env vars), NOT with a VITE_ prefix.
# VITE_-prefixed variables are inlined into the public browser bundle; a Gemini
# key there is fully exposed. The app calls the /api/gemini serverless proxy
# (see api/gemini.js), which reads this variable via process.env.GEMINI_API_KEY.
GEMINI_API_KEY=
